{
  "scopeName": "source.fluence",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#brackets" },  
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.block.fluence", "begin": "#\\*", "end": "\\*#" },
        { "name": "comment.line.number-sign.fluence", "match": "#.*$" }
      ]
    },
    "strings": {
      "patterns": [
        { 
          "name": "string.quoted.double.fluence", 
          "begin": "f?\"", 
          "end": "\"", 
          "patterns": [{ "name": "constant.character.escape.fluence", "match": "\\\\." }] 
        },
        { 
          "name": "string.quoted.single.fluence", 
          "begin": "'", 
          "end": "'", 
          "patterns": [{ "name": "constant.character.escape.fluence", "match": "\\\\." }] 
        }
      ]
    },
    "brackets": {
      "match": "(\\{|\\}|\\[|\\]|\\(|\\))",
      "name": "punctuation.bracket.fluence"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.fluence",
          "match": "\\b(if|else|while|until|for|in|match|rest|return|break|continue|try|catch|throw|times|as|unless|loop|func|struct|enum|trait|use|root|solid|global|self|nil|true|false|is|and|or|not)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.fluence",
          "match": "\\-\\>|=>|\\|\\>|\\<\\~\\|\\??|\\<\\|\\??|\\<\\d+\\!?\\|\\??|\\|\\>\\>\\=|\\<\\=\\=\\||\\<\\!\\=\\||\\<\\<\\||\\<\\>\\||\\<\\<\\=\\||\\<\\>\\=\\||\\<\\|\\|\\=\\=\\||\\<\\|\\|\\!\\=\\||\\<\\|\\|\\<\\||\\<\\|\\|\\<\\=\\||\\<\\|\\|\\>\\||\\<\\|\\|\\>\\=\\||\\<\\?\\?\\||\\<\\|\\|\\?\\?\\||\\|\\?\\?|\\?\\.|\\?\\:|\\.\\+\\+|\\.\\-\\-|\\>\\<|\\.\\.\\.?|\\+|\\-|\\*|/|%|\\*\\*|==|!=|<=|>=|<|>|=|\\+=|\\-=|\\*=|/=|%=|\\&="
        }
      ]
    },
    "functions": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": { "1": { "name": "entity.name.function.fluence" } }
    },
    "types": {
      "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b",
      "name": "storage.type.fluence"
    },
    "constants": {
      "match": "\\b\\d+\\.?\\d*([eE][+-]?\\d+)?f?\\b",
      "name": "constant.numeric.fluence"
    },
    "variables": {
      "match": "\\b([a-z_][a-zA-Z0-9_]*)\\b",
      "name": "variable.other.readwrite.fluence"
    }
  }
}