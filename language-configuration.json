{
  "comments": {
    "lineComment": "#",
    "blockComment": ["#*", "*#"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*(\\{|\\()\\s*$",
    "decreaseIndentPattern": "^\\s*(\\}|\\))\\s*$"
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([_a-zA-Z][_a-zA-Z0-9]*)|([<|>~!?=.:+-]+)"
}